.title{
    font-size:22px;
    font-weight:bold;
    color:#FFD700;
    letter-spacing:2px;
    text-align:center;

    text-shadow:
        0 1px 0 #fff7b2,
        0 2px 0 #f6c600,
        0 3px 0 #c28f00,
        0 0 10px #ffd700,
        0 0 20px #ffea00,
        0 0 35px #ffcc00;
}